@page
@model Jobs.Pages.Admin.IndexModel
@{
    Layout = "_Admin_Layout";  
}
<style>
    * {
        box-sizing: border-box;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 15px; /* Spacing between columns */
        margin: 15px 0;
    }

    .column {
        flex: 1 0 calc(100% - 20px); /* Mobile: full width */
        min-width: 150px; /* Minimum column width */
        padding: 15px;
        text-align: center;
        border-radius: 8px; /* Optional: rounded corners */
    }

    /* Tablet view: 2 columns */
    @@media (min-width: 768px) {
        .column {
            flex: 1 0 calc(50% - 20px);
        }
    }

    /* Desktop view: 4 columns */
    @@media (min-width: 992px) {
        .column {
            flex: 1 0 calc(25% - 20px);
            max-width: calc(25% - 20px);
        }
    }

    .column a {
        display: block;
        padding: 15px 5px;
        color: #000;
        text-decoration: none;
        font-size: 1.1em;
        font-weight: 500;
    }

    .column i {
        font-size: 2em;
        display: block;
        margin-bottom: 10px;
    }

    .column:hover {
        transform: translateY(-5px);
        transition: transform 0.3s ease;
    }

    .auto-style1 {
        color: #006600;
    }
</style>

